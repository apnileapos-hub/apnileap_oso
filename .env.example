# Required — Jira credentials
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here

# Optional — override defaults
JIRA_BASE_URL=https://devcobraaa.atlassian.net
JIRA_PROJECT_KEY=SCRUM
PORT=5000

# Optional — separate Confluence credentials (falls back to Jira credentials if unset)
# CONFLUENCE_EMAIL=your-confluence-email@example.com
# CONFLUENCE_API_TOKEN=your-confluence-api-token-here
# CONFLUENCE_BASE_URL=https://devcobraaa.atlassian.net

